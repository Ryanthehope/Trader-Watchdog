generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Staff {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  name        String?
  totpSecret  String?
  totpEnabled Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Member {
  id                       String           @id @default(cuid())
  slug                     String           @unique
  tvId                     String           @unique
  name                     String
  trade                    String
  location                 String
  checks                   Json
  /// Optional structured vetting UI for the public profile (sections + accordion items).
  vettingItems             Json?
  verifiedSince            String
  blurb                    String
  /// Optional logo under uploads/member-profile-logos/{id}/ (public /api/members/.../profile-logo).
  profileLogoStoredName    String?
  /// Multiline address on quotes & customer invoices (your business — not Trader Watchdog billing).
  invoiceAddress           String?
  /// Shown on customer invoices for bank transfer (account name, sort code, account no., reference).
  invoiceBankDetails       String?
  invoicePhone             String?
  /// Shown on quotes/invoices; if empty, login email is used when present.
  invoiceEmail             String?
  vatNumber                String?
  /// When false, customer invoices hide VAT fields and store vatPence as 0.
  vatRegistered            Boolean          @default(false)
  /// Brand accent for quote/invoice PDFs (hex, e.g. #0d9488).
  documentAccentHex        String?
  /// "standard" | "bold" — PDF layout density.
  documentLayout           String?
  /// Login email for the member portal (set by staff)
  loginEmail               String?          @unique
  /// bcrypt hash; null = portal access not enabled
  passwordHash             String?
  /// After provisioning with a temp password; cleared when they set a new password.
  mustChangePassword       Boolean          @default(false)
  /// SHA-256 hash of a random token sent to the member for password reset.
  passwordResetToken       String?
  /// When the passwordResetToken expires (1 hour from issue).
  passwordResetExpiry      DateTime?
  /// When set with membershipBillingType, access ends after this instant (GoCardless period end or manual term).
  membershipExpiresAt      DateTime?
  /// "goCardless" | "manual" — null with null expiry = legacy grandfathered access.
  membershipBillingType    String?
  verificationProvider            String?
  verificationStatus              VerificationStatus @default(NOT_STARTED)
  verificationSubmittedAt         DateTime?
  verificationApprovedAt          DateTime?
  verificationRejectedAt          DateTime?
  verificationProviderApplicantId String?
  verificationProviderSessionId   String?
  verificationFailureReason       String?
  addressVerificationStatus           VerificationStatus @default(NOT_STARTED)
  addressVerificationApprovedAt       DateTime?
  addressVerificationRejectedAt       DateTime?
  addressVerificationFailureReason    String?
  addressVerificationMatchedAddress   String?
  addressVerificationMatchedApplication Boolean?
  goCardlessCustomerId         String?
  goCardlessSubscriptionId     String?
  /// Mirrors GoCardless subscription.status (active, canceled, past_due, …).
  goCardlessSubscriptionStatus String?
  /// Discounted renewal price (pence) if a partial discount was applied at initial checkout. Null = full price.
  membershipRenewalPricePence  Int?
  /// Staff-only: portal membership never expires (overrides billing/expiry).
  membershipUnlimited      Boolean          @default(false)
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt
  documents                MemberDocument[]
  /// Filled when this profile was auto-created from an approved application.
  sourceApplication        Application?     @relation("MemberFromApprovedApplication")
  insurancePolicies        Insurance[]
}

model Insurance {
  id       String @id @default(cuid())
  memberId String
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  ///Type of Insurance: "Public liability", "Employers Liability", "Personal Indemnity@, etc.
  type         String
  provider     String?
  policyNumber String?

  expiryDate      DateTime
  ///Calculated: expiryDate + grace period (7-10 days), null if not yet expired
  graceExpiryDate DateTime?

  /// "active" | "expiring_soon" | "in_grace" | "expired"
  status String @default("active")

  /// Track when alerts were sent: {"90days": "2026-01-15T10:00:00Z", "60days": null, "30days": null}
  alertsSent      Json?
  lastAlertSentAt DateTime?

  /// Stored filename for uploaded policy document
  documentStoredName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([memberId])
  @@index([status])
  @@index([expiryDate])
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model MemberDocument {
  id           String   @id @default(cuid())
  memberId     String
  member       Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  storedName   String
  originalName String
  mimeType     String
  sizeBytes    Int
  createdAt    DateTime @default(now())

  @@index([memberId])
}

enum ApplicationStatus {
  PENDING
  REVIEWING
  CONTACTED
  APPROVED
  DECLINED
}

enum VerificationStatus {
  NOT_STARTED
  IN_PROGRESS
  APPROVED
  REJECTED
}

model Application {
  id                           String                @id @default(cuid())
  company                      String
  legalStructure               String?
  tradingAddress               String?
  trade                        String
  identifiablePerson           String?
  identifiablePersonAddress    String?
  email                        String
  phone                        String?
  postcode                     String
  wasteCarrierRequired         String?
  wasteCarrierNumber           String?
  gasSafeRequired              String?
  gasSafeNumber                String?
  icoNumber                    String?
  businessDescription          String?
  documentsConfirmed           Boolean               @default(false)
  agreementAccepted            Boolean               @default(false)
  enquiriesAccepted            Boolean               @default(false)
  status                       ApplicationStatus     @default(PENDING)
  /// Set when staff first marks the application APPROVED (used for payment window).
  approvedAt                   DateTime?
  notes                        String?
  /// Legacy free-text checklist; optional if using vettingState.
  vettingChecklist             String?
  /// Structured vetting sections { sectionId: { done, notes } }.
  vettingState                 Json?
  registrationFeePaidAt        DateTime?
  membershipSubscribed         Boolean               @default(false)
  /// Expiry for staff-recorded manual membership (copied to Member on provision / updates).
  manualMembershipExpiresAt    DateTime?
  verificationProvider            String?
  verificationStatus              VerificationStatus @default(NOT_STARTED)
  verificationSubmittedAt         DateTime?
  verificationApprovedAt          DateTime?
  verificationRejectedAt          DateTime?
  verificationProviderApplicantId String?
  verificationProviderSessionId   String?
  verificationFailureReason       String?
  addressVerificationStatus           VerificationStatus @default(NOT_STARTED)
  addressVerificationApprovedAt       DateTime?
  addressVerificationRejectedAt       DateTime?
  addressVerificationFailureReason    String?
  addressVerificationMatchedAddress   String?
  addressVerificationMatchedApplication Boolean?
  /// First name of the staff member who set the application status to APPROVED.
  approvedByStaffName             String?
  goCardlessCustomerId             String?
  /// GoCardless mandate ID captured from the billing request (used to auto-charge membership on approval).
  goCardlessMandateId              String?
  /// Discounted renewal price (pence) set when a partial discount code was used at membership checkout.
  membershipRenewalPricePence      Int?
  /// Plain one-time password for /join until first login or expiry (14d at provision).
  pendingPortalPassword        String?
  pendingPortalPasswordExpires DateTime?
  createdAt                    DateTime              @default(now())
  updatedAt                    DateTime              @updatedAt
  documents                    ApplicationDocument[]
  createdMemberId              String?               @unique
  createdMember                Member?               @relation("MemberFromApprovedApplication", fields: [createdMemberId], references: [id], onDelete: SetNull)
}

model ApplicationDocument {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  storedName    String
  originalName  String
  mimeType      String
  sizeBytes     Int
  createdAt     DateTime    @default(now())

  @@index([applicationId])
}

model OrganizationSettings {
  id                                String  @id @default("default")
  revenueMtdCents                   Int     @default(0)
  outstandingCents                  Int     @default(0)
  workspaceName                     String?
  /// White-label product name (portal, emails, public UI). Falls back to workspaceName then "Trader Watchdog".
  siteDisplayName                   String?
  /// Base URL for email links (e.g. https://app.yoursite.com). Falls back to PUBLIC_SITE_URL env.
  publicSiteUrl                     String?
  announcementEmail                 String?
  /// Comma-separated ops addresses for system emails (overrides announcementEmail when set).
  adminNotifyEmails                 String?
  /// Outbound SMTP — optional; env vars override when set on the server.
  smtpHost                          String?
  smtpPort                          Int?
  smtpSecure                        Boolean @default(false)
  smtpUser                          String?
  smtpPass                          String?
  /// Sender for system emails, e.g. "Acme Verify <noreply@acme.com>"
  mailFrom                          String?
  /// GoCardless (admin-configurable; secret also via GO_CARDLESS_SECRET_KEY env)
  billingEnabled                    Boolean @default(false)
  goCardlessPublishableKey              String?
  goCardlessSecretKey                   String?
  goCardlessWebhookSecret               String?
  /// Shown on GoCardless Checkout (inline price_data — no Dashboard Price IDs required)
  checkoutMembershipName            String?
  checkoutRegistrationFeeName       String?
  checkoutMembershipPence           Int     @default(9480)
  checkoutRegistrationFeePence      Int     @default(1500)
  /// reCAPTCHA v2
  recaptchaEnabled                  Boolean @default(false)
  recaptchaSiteKey                  String?
  recaptchaSecretKey                String?
  /// Staff security
  staffRequire2fa                   Boolean @default(false)
  /// PNG/JPG logo file name under org branding upload dir (served at /api/public/branding/logo).
  brandingLogoStoredName            String?
  /// Shown on member billing + synced context; GoCardless PDFs use Dashboard branding after sync.
  invoiceLegalName                  String?
  invoiceVatNumber                  String?
  invoiceAddress                    String?
  invoiceFooterNote                 String?
  /// Last GoCardless File id used for account branding (optional).
  goCardlessBrandingLogoFileId          String?
  /// GA4 Measurement ID (G-XXXXXXXXXX) — loads gtag on the public site (not /staff).
  googleAnalyticsMeasurementId      String?
  /// GA4 numeric Property ID (Admin → Property settings) for Data API reports in Staff → Analytics.
  googleAnalyticsPropertyId         String?
  /// Google Cloud service account JSON (Data API). Stored encrypted-at-rest only via your own DB backups policy.
  googleAnalyticsServiceAccountJson String?
}

model Guide {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  excerpt   String
  readTime  String
  body      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
