# SQLite path: relative to prisma/ (e.g. ./dev.db → server/prisma/dev.db). For production, use an
# absolute path outside the deploy folder so uploads/redeploys do not replace the file, e.g.:
# DATABASE_URL="file:/var/lib/tradeverify/app.db"
DATABASE_URL="file:./dev.db"

# HTTP(S) port. Use 443 only with TLS below (often needs admin / root to bind).
PORT=3001

# HTTPS — set both to PEM paths (absolute or relative to server/). Required for real HTTPS on 443.
# SSL_KEY_FILE=./certs/privkey.pem
# SSL_CERT_FILE=./certs/fullchain.pem

# Optional: member document uploads directory (default: server/uploads/member-documents)
# MEMBER_UPLOAD_DIR="D:\\path\\to\\uploads"

# Optional: join application attachments (default: server/uploads/application-documents)
# APPLICATION_UPLOAD_DIR="D:\\path\\to\\application-uploads"

# Optional: forward join applications to Zapier/Slack (server-side, in addition to DB)
# APPLICATION_WEBHOOK_URL="https://..."
# APPLICATION_WEBHOOK_SECRET=""
JWT_SECRET="change-this-to-a-long-random-string-in-production"

# Stripe (optional override of DB Integrations screen; webhook signing secret here or in admin)
# STRIPE_SECRET_KEY="sk_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."

# reCAPTCHA v2 (optional override of admin Integrations secret)
# RECAPTCHA_SECRET_KEY="..."

# Used for Stripe Checkout success/cancel URLs when Origin header is missing
# PUBLIC_SITE_URL="http://localhost:5173"

# Outbound email (SMTP) — optional. Prefer Staff → Settings → SMTP in the app (stored in DB).
# Environment variables below override database values when set (per field).
# Recipients: ADMIN_NOTIFY_EMAILS overrides DB notification list / ops email, else CONTACT_EMAIL.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM="TradeVerify <noreply@yourdomain.com>"
# ADMIN_NOTIFY_EMAILS="ops@yourdomain.com,second@yourdomain.com"

# Public Contact page (mailto). Loaded by the API — restart server after changing; no Vite rebuild.
# CONTACT_EMAIL=hello@yourdomain.co.uk
# PUBLIC_CONTACT_EMAIL=hello@yourdomain.co.uk

STAFF_SEED_EMAIL="admin@tradeverify.local"
STAFF_SEED_PASSWORD="ChangeThisPassword!"
STAFF_SEED_NAME="Administrator"

# Demo member portal (seed only) — Riverside Electrical
# MEMBER_DEMO_EMAIL="member@riverside.demo"
# MEMBER_DEMO_PASSWORD="MemberDemo123!"

# --- Optional: GA4 Data API (Staff → Analytics) — optional env overrides only ---
# Prefer Staff → Integrations → Google Analytics: numeric Property ID + paste service account JSON.
# Use these only if you want file-based credentials or to override DB values:
# GA4_PROPERTY_ID="123456789"
# GOOGLE_APPLICATION_CREDENTIALS="/path/to/service-account.json"
# In GA4: Admin → Property access management → service account email as Viewer.
