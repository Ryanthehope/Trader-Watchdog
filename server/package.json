{
  "name": "tradeverify-server",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build:client": "npm run build:client --prefix ..",
    "build": "node ./node_modules/prisma/build/index.js generate && node ./node_modules/typescript/lib/tsc.js",
    "start": "node dist/index.js",
    "db:push": "node ./node_modules/prisma/build/index.js db push",
    "db:migrate": "node ./node_modules/prisma/build/index.js migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "postinstall": "node ./node_modules/prisma/build/index.js generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@google-analytics/data": "^4.12.1",
    "@prisma/client": "^6.19.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.4",
    "otplib": "^13.4.0",
    "prisma": "^6.19.0",
    "qrcode": "^1.5.4",
    "stripe": "^21.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.19.0",
    "@types/nodemailer": "^7.0.11",
    "@types/qrcode": "^1.5.6",
    "tsx": "^4.20.6",
    "typescript": "~5.6.3"
  }
}
